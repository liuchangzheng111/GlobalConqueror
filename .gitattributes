# 二进制资源（图片/纹理）
*.psd filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.bmp filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text

# 3D模型/动画
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.anim filter=lfs diff=lfs merge=lfs -text
*.prefab filter=lfs diff=lfs merge=lfs -text  # 超大预制体

# 音频/视频
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text

# 插件/动态库
*.dll filter=lfs diff=lfs merge=lfs -text    # Windows动态库
*.dylib filter=lfs diff=lfs merge=lfs -text # macOS动态库
*.so filter=lfs diff=lfs merge=lfs -text    # Linux动态库

# Unity特殊大资源（如TextMesh Pro字体SDF）
"Assets/TextMesh Pro/Resources/Fonts & Materials/Huiwen Regular Script SDF.asset" filter=lfs diff=lfs merge=lfs -text

# ========== 文本文件（确保Git正确处理换行符） ==========
# 代码/配置文件（标记为文本，统一换行符）
*.cs text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf